#include <bits/stdc++.h>
using namespace std;

int dist2(pair<int, int> a, pair<int, int> b)
{
    int dx = a.first - b.first;
    int dy = a.second - b.second;
    return dx * dx + dy * dy;
}

int bruteForce(vector<pair<int, int>> &P, int l, int r)
{
    int mn = INT_MAX;
    for (int i = l; i <= r; i++)
    {
        for (int j = i + 1; j <= r; j++)
        {
            mn = min(mn, dist2(P[i], P[j]));
        }
    }
    return mn;
}

int stripClosest(vector<pair<int, int>> &strip, int d)
{
    sort(strip.begin(), strip.end(), [](auto &a, auto &b) { return a.second < b.second; });
    int n = strip.size();
    int mn = d;
    for (int i = 0; i < n; i++)
    {
        for (int j = i + 1; j < n && (strip[j].second - strip[i].second) * (strip[j].second - strip[i].second) < mn; j++)
        {
            mn = min(mn, dist2(strip[i], strip[j]));
        }
    }
    return mn;
}

int closestUtil(vector<pair<int, int>> &P, int l, int r)
{
    int n = r - l + 1;
    if (n <= 3)
        return bruteForce(P, l, r);
    int mid = (l + r) / 2;
    int midx = P[mid].first;
    int dl = closestUtil(P, l, mid);
    int dr = closestUtil(P, mid + 1, r);
    int d = min(dl, dr);
    vector<pair<int, int>> strip;
    for (int i = l; i <= r; i++)
    {
        int dx = P[i].first - midx;
        if (dx * dx < d)
            strip.push_back(P[i]);
    }
    return min(d, stripClosest(strip, d));
}

int closestPair(vector<pair<int, int>> &P)
{
    sort(P.begin(), P.end(), [](auto &a, auto &b) { return a.first < b.first; });
    return closestUtil(P, 0, P.size() - 1);
}

int main()
{
    int n;
    cout << "Enter number of points: ";
    cin >> n;
    vector<pair<int, int>> P(n);
    for (int i = 0; i < n; i++)
    {
        cout << "Enter point " << i + 1 << " (x y): ";
        cin >> P[i].first >> P[i].second;
    }
    int ans = closestPair(P);
    cout << "The smallest distance between points is: " << ans << endl;
}